{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Benchmark float",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/main",
            "cwd" : "${workspaceFolder}",
            "args": [
                "-n 5000",
                "-i 5",
                "-j 128",
                "-k 128",
                "-f"
            ]
        },
        {
            "name": "Benchmark double",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/main",
            "cwd" : "${workspaceFolder}",
            "args": [
                "-n 5000",
                "-i 5",
                "-j 128",
                "-k 128",
                "-d"
            ]
        },
        {
            "name": "Benchmark All",
            "type": "cuda-gdb",
            "request": "launch",
            "program": "${workspaceFolder}/build/main",
            "cwd" : "${workspaceFolder}",
            "args": [
                "-n 5000",
                "-i 5",
                "-j 128",
                "-k 128",
                "-fd",
            ]
        }
    ]
}